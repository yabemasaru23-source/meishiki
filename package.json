<style>
:root{
  --ink:#14161a;
  --ink-panel:#1c1f26;
  --ink-line:#333842;
  --gofun:#ece8df;
  --nibi:#8b919c;
  --moku:#4f9e6f;
  --ka:#d2453e;
  --do:#c9922e;
  --kin:#bfc5cd;
  --sui:#4272ab;
  --display:"Zen Old Mincho",serif;
  --body:"Noto Sans JP",system-ui,sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0}
body{
  background:var(--ink);
  color:var(--gofun);
  font-family:var(--body);
  font-weight:300;
  line-height:1.75;
  -webkit-font-smoothing:antialiased;
}
.wrap{max-width:860px;margin:0 auto;padding:0 20px 80px}

/* ---- header ---- */
header{padding:64px 0 40px;text-align:center;border-bottom:1px solid var(--ink-line)}
.eyebrow{
  font-family:var(--body);font-size:.68rem;font-weight:500;
  letter-spacing:.42em;color:var(--nibi);text-indent:.42em;margin-bottom:22px;
}
h1{
  font-family:var(--display);font-weight:900;
  font-size:clamp(1.9rem,6vw,2.9rem);letter-spacing:.16em;
  text-indent:.16em;line-height:1.3;
}
.lede{margin-top:18px;font-size:.86rem;color:var(--nibi);letter-spacing:.03em}

/* ---- form ---- */
.form{
  margin:40px 0;padding:28px 24px;
  background:var(--ink-panel);border:1px solid var(--ink-line);
}
.grid{display:grid;grid-template-columns:1fr 1fr;gap:18px 20px}
.field{display:flex;flex-direction:column;gap:8px}
.field.full{grid-column:1/-1}
label{font-size:.72rem;letter-spacing:.14em;color:var(--nibi);font-weight:500}
input,select{
  background:#12141a;border:1px solid var(--ink-line);color:var(--gofun);
  font-family:var(--body);font-size:.98rem;padding:11px 12px;border-radius:0;
  width:100%;
}
input:focus,select:focus{outline:2px solid var(--do);outline-offset:1px;border-color:transparent}
.hint{font-size:.68rem;color:#666c77;letter-spacing:.02em}
button{
  grid-column:1/-1;margin-top:6px;
  background:var(--gofun);color:var(--ink);border:none;
  font-family:var(--display);font-weight:600;font-size:1rem;letter-spacing:.3em;
  text-indent:.3em;padding:15px;cursor:pointer;transition:opacity .18s;
}
button:hover{opacity:.82}
button:focus-visible{outline:2px solid var(--do);outline-offset:3px}

/* ---- result ---- */
#result{display:none}
#result.on{display:block}
.who{
  font-family:var(--display);font-size:1.5rem;letter-spacing:.1em;
  text-align:center;margin:52px 0 6px;
}
.who-sub{text-align:center;font-size:.76rem;color:var(--nibi);letter-spacing:.12em;margin-bottom:36px}

.sec-label{
  font-size:.68rem;letter-spacing:.34em;color:var(--nibi);text-indent:.34em;
  padding-bottom:10px;margin:56px 0 20px;border-bottom:1px solid var(--ink-line);
  font-weight:500;
}

/* ---- 命式表 ---- */
.chart{width:100%;border-collapse:collapse;font-size:.86rem;table-layout:fixed}
.chart th,.chart td{
  border:1px solid var(--ink-line);padding:12px 4px;text-align:center;vertical-align:middle;
}
.chart thead th{
  font-family:var(--display);font-weight:600;font-size:.9rem;letter-spacing:.08em;
  color:var(--gofun);background:#20242c;
}
.chart th.rowlab{
  width:20%;font-family:var(--display);font-weight:400;font-size:.78rem;
  color:var(--nibi);background:#181b21;letter-spacing:.06em;line-height:1.4;
}
.ganshi{font-family:var(--display);font-size:1.5rem;font-weight:600;letter-spacing:.05em;display:block;margin:3px 0}
.tiny{font-size:.64rem;color:var(--nibi);display:block;letter-spacing:.04em}
.no{font-size:.7rem;color:#6a7079;display:block;margin-top:5px;font-variant-numeric:tabular-nums}
.star{font-family:var(--display);font-size:1rem;letter-spacing:.04em}
.energy{font-size:.66rem;color:var(--nibi);display:block;font-variant-numeric:tabular-nums}
td.empty{color:#3d434c}

/* ---- 天中殺 ---- */
.tcs{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:8px}
.tcs-card{background:var(--ink-panel);border:1px solid var(--ink-line);padding:18px 16px;text-align:center}
.tcs-card .k{font-size:.66rem;letter-spacing:.2em;color:var(--nibi);display:block;margin-bottom:8px}
.tcs-card .v{font-family:var(--display);font-size:1.55rem;letter-spacing:.12em}
.chusatsu{
  margin-top:16px;padding:16px 18px;border-left:2px solid var(--do);
  background:#1a1c1f;font-size:.84rem;line-height:1.9;
}
.chusatsu b{font-family:var(--display);font-weight:600;letter-spacing:.06em;color:var(--do)}
.chusatsu.none{border-left-color:var(--ink-line);color:var(--nibi)}

/* ---- 五行 (signature) ---- */
.gogyo-wrap{display:grid;grid-template-columns:1.1fr .9fr;gap:28px;align-items:center}
svg.cycle{width:100%;height:auto;overflow:visible}
.legend{display:flex;flex-direction:column;gap:2px}
.bar-row{display:grid;grid-template-columns:2.2rem 1fr 1.6rem;align-items:center;gap:12px;padding:7px 0}
.bar-name{font-family:var(--display);font-size:1.05rem;letter-spacing:.05em}
.bar-track{height:5px;background:#252932;position:relative}
.bar-fill{height:100%;transition:width .7s cubic-bezier(.2,.8,.2,1)}
.bar-num{font-size:.8rem;color:var(--nibi);text-align:right;font-variant-numeric:tabular-nums}
.gogyo-note{margin-top:20px;font-size:.8rem;color:var(--nibi);line-height:1.9;grid-column:1/-1}
.gogyo-note b{color:var(--gofun);font-weight:500}

/* ---- footer ---- */
footer{margin-top:72px;padding-top:24px;border-top:1px solid var(--ink-line);font-size:.7rem;color:#5c626b;line-height:2;text-align:center}

@media(max-width:640px){
  .grid{grid-template-columns:1fr}
  .gogyo-wrap{grid-template-columns:1fr;gap:8px}
  .chart{font-size:.74rem}
  .chart th.rowlab{width:19%;font-size:.68rem}
  .ganshi{font-size:1.2rem}
  .tcs{grid-template-columns:1fr}
}
@media(prefers-reduced-motion:reduce){*{transition:none!important;animation:none!important}}
</style>
